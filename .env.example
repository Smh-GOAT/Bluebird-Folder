NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Bilibili runtime defaults (can be overridden in /settings)
BILIBILI_USER_AGENT=
BILIBILI_COOKIE=
BILIBILI_DOWNLOADER_TIMEOUT_MS=600000

# Xiaohongshu parser (Milestone 2 mock-ready)
XIAOHONGSHU_USER_AGENT=
XIAOHONGSHU_COOKIE=
XIAOHONGSHU_DOWNLOADER_TIMEOUT_MS=600000

# Qwen3-ASR
QWEN3_ASR_API_KEY=
QWEN3_ASR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
QWEN3_ASR_MODEL=qwen3-asr-flash

# LLM Provider Configuration (Milestone 3)
# Options: kimi | openai | anthropic | qwen
LLM_PROVIDER=kimi

# Kimi (Primary - Chinese model)
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k

# OpenAI (Fallback)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic (Fallback)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Qwen/DashScope (Chinese model)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.5-plus
